# Compiled example binaries (regenerate with scripts/build_all.sh).
/bin/

# Stray binaries built at the repo root (e.g. `spinel ... -o fyel_srvr`).
/fyel_srvr
/fyel_srvr_1
/fyel_srvr_2
/fyel_srvr_3
/fyel_srvr_4
/fyel_srvr_5
/fyel_srvr_6
/todo_cli
/log_report
/token_api
/parallel_digest

# Scratch data written by the CLI examples at run time. The tracked sample
# input (data/sample_access.log) is NOT ignored -- only generated JSON state.
/todo.json
*.todo.json

# C intermediates that a compiler run may leave behind.
*.o
*.dSYM/

# OS / editor cruft.
.DS_Store
